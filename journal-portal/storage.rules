rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /journals/{path=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /boardMembers/{path=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
