rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function validContactCreate() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt', 'read'])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 200
        && data.email is string
        && data.email.size() <= 320
        && data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        && data.message is string
        && data.message.size() > 0
        && data.message.size() <= 10000
        && data.read == false
        && data.createdAt is timestamp;
    }

    match /journals/{journalId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      // Public view-count bumps: only viewCount + updatedAt, and viewCount must increase by exactly 1
      // (handles missing viewCount via get(..., 0); required for new issues created without the field).
      allow update: if isAdmin()
        || (
             request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['viewCount', 'updatedAt'])
             && request.resource.data.viewCount is int
             && request.resource.data.updatedAt is timestamp
             && request.resource.data.viewCount
                  == resource.data.get('viewCount', 0) + 1
           );
    }

    match /articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /boardMembers/{memberId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /contactSubmissions/{id} {
      allow create: if validContactCreate();
      allow read, update, delete: if isAdmin();
    }

    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
